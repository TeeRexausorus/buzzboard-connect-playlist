# Backend
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Frontend (optional, for production deployments)
# VITE_API_BASE_URL=https://your-api-domain.tld

# Option 1: full DSN
# Local:
# DATABASE_URL=postgres://user:password@localhost:5432/buzzboard
# Cloud providers often require TLS:
# DATABASE_URL=postgres://user:password@host:5432/db?sslmode=require

# Option 2: split variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buzzboard
DB_USER=postgres
DB_PASSWORD=postgres
# For managed Postgres, set true
DB_SSL=true
